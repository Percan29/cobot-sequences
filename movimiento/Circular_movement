circle_points = [
    {"x": 0.3, "y": 0.2},
    {"x": 0.35, "y": 0.25},
    {"x": 0.4, "y": 0.2}
]

def circular_movement(points):
    for p in points:
        print(f"Moving to circular point X={p['x']} Y={p['y']}")
        print("Following circular trajectory")

circular_movement(circle_points)

# Note:
# Circular movement is used for arcs, polishing, and curved welds.
